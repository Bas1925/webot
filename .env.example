# Copy this file to ".env" and fill in your values, then run:  node --env-file=.env server.js
# (Node 20+ supports --env-file. Without a .env, leads fall back to leads.local.json.)

# --- MongoDB (where leads are stored) ---
# Local:  mongodb://127.0.0.1:27017
# Atlas:  mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net
MONGODB_URI=
DB_NAME=webot
LEADS_COLLECTION=leads

# --- Optional: email me when a new lead arrives (Gmail) ---
# Create a Gmail "App Password" (Google Account → Security → 2-Step Verification → App passwords).
# Leave blank to disable email and just store leads in MongoDB.
GMAIL_USER=
GMAIL_APP_PASSWORD=
MAIL_TO=

# --- Server ---
PORT=7777
